#!/usr/bin/env bash
set -euo pipefail

REPO_URL="https://github.com/Ahasseyp/gswitch"
RAW_URL="https://raw.githubusercontent.com/Ahasseyp/gswitch/main"
DATA_DIR="${HOME}/.local/share/gswitch"
VERSION_FILE="${DATA_DIR}/version"

red()   { printf '\033[31m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }
bold()  { printf '\033[1m%s\033[0m\n' "$*"; }

check_only=false
force=false

for arg in "${@:-}"; do
  case "$arg" in
    --check) check_only=true ;;
    --force) force=true ;;
    -h|--help)
      echo "Usage: gsupdate [--check | --force]"
      echo ""
      echo "  (no flags)  check for a newer version and install if found"
      echo "  --check     print version status and exit (0 = up to date, 1 = update available)"
      echo "  --force     reinstall even if already on the latest version"
      exit 0
      ;;
    *) ;;
  esac
done

local_version=$(cat "$VERSION_FILE" 2>/dev/null || echo "0.0.0")

echo "Checking for updates..."
remote_version=$(curl -fsSL --max-time 10 "${RAW_URL}/VERSION" 2>/dev/null | tr -d '[:space:]' || true)

if [[ -z "$remote_version" ]]; then
  red "Could not reach GitHub. Check your connection and try again."
  exit 1
fi

if $check_only; then
  if [[ "$remote_version" == "$local_version" ]]; then
    green "gswitch is up to date ($local_version)."
    exit 0
  else
    echo "Update available: $local_version → $remote_version"
    exit 1
  fi
fi

if [[ "$remote_version" == "$local_version" ]] && ! $force; then
  green "gswitch is already up to date ($local_version)."
  exit 0
fi

if $force; then
  bold "Force-reinstalling gswitch $remote_version..."
else
  bold "Updating gswitch $local_version → $remote_version..."
fi

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

curl -fsSL "${REPO_URL}/archive/refs/heads/main.tar.gz" | tar -xz -C "$tmp" --strip-components=1

bash "${tmp}/install.sh"
