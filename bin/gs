#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "Usage: gs [<query>]"
  echo "       gs --last"
  echo "       gs -"
  echo ""
  echo "Fuzzy-switch to a tracked branch. Optionally pre-filter with <query>."
  echo ""
  echo "Flags:"
  echo "  --last, -   switch to the previously visited branch"
  echo ""
  echo "Keys:"
  echo "  Enter     switch to selected branch"
  echo "  ctrl-x    untrack selected branch"
  echo "  ctrl-c    cancel"
  exit 0
fi

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "Not in a git repo."; exit 1; }
repo_id=$(printf '%s' "$repo_root" | shasum | cut -d' ' -f1)
TRACKED_FILE="${HOME}/.local/share/gswitch/${repo_id}/branches"
LAST_FILE="${HOME}/.local/share/gswitch/${repo_id}/last_branch"

current_branch=$(git branch --show-current 2>/dev/null || true)

if [[ -f "$TRACKED_FILE" ]]; then
  tmp=$(mktemp)
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    git show-ref --verify --quiet "refs/heads/$b" && echo "$b"
  done < "$TRACKED_FILE" > "$tmp"
  mv "$tmp" "$TRACKED_FILE"
fi

if [[ "${1:-}" == "--last" || "${1:-}" == "-" ]]; then
  [[ -f "$LAST_FILE" ]] || { echo "No previous branch recorded."; exit 1; }
  branch=$(cat "$LAST_FILE")
  [[ -n "$branch" ]] || { echo "No previous branch recorded."; exit 1; }
else
  list_entries() {
    [[ ! -f "$TRACKED_FILE" ]] && return 0
    grep -vxF "$current_branch" "$TRACKED_FILE" 2>/dev/null | grep -v '^$' | sed 's/^/  /' || true
  }

  if [[ -z "$(list_entries)" ]]; then
    echo "No branches to show."
    exit 0
  fi

  # TRACKED_FILE and current_branch are expanded now (script time) into the bind string.
  # $NF and the grep/sed vars expand later inside fzf's execute/reload subshells.
  selected=$(list_entries | fzf --ansi \
    --header "Switch to branch · ctrl-x: untrack" \
    --reverse \
    --query "${1:-}" \
    --select-1 \
    --bind "ctrl-x:execute-silent(
      branch=\$(echo {} | awk '{print \$NF}')
      grep -vxF \"\$branch\" '$TRACKED_FILE' > '${TRACKED_FILE}.tmp' && mv '${TRACKED_FILE}.tmp' '$TRACKED_FILE'
    )+reload(
      grep -vxF '$current_branch' '$TRACKED_FILE' 2>/dev/null | grep -v '^$' | sed 's/^/  /' || true
    )") || exit 0

  [[ -z "$selected" ]] && exit 0
  branch=$(echo "$selected" | awk '{print $NF}')
fi

if [[ -n "$(git status --porcelain)" ]]; then
  echo "Working tree is dirty."
  echo "  [g] gwip then switch (default)"
  echo "  [s] switch anyway (might fail)"
  echo "  [a] abort"
  read -rp "Choice [g]: " answer

  if [[ -z "$answer" || "$answer" =~ ^[Gg]$ ]]; then
    git add -A
    git rm "$(git ls-files --deleted)" 2>/dev/null || true
    git commit --no-verify --no-gpg-sign --message "--wip-- [skip ci]"
  elif [[ "$answer" =~ ^[Ss]$ ]]; then
    : # proceed to git switch as-is
  else
    echo "Aborted."
    exit 1
  fi
fi

echo "$current_branch" > "$LAST_FILE"
git switch "$branch"

if git rev-list --max-count=1 --format="%s" HEAD | grep -q "\-\-wip\-\-"; then
  git reset HEAD~1
  echo "Unwipped."
fi

CHECK_FILE="${HOME}/.local/share/gswitch/last_update_check"
now=$(date +%s)
last=$(cat "$CHECK_FILE" 2>/dev/null || echo 0)

if (( now - last > 86400 )); then
  echo "$now" > "$CHECK_FILE"
  (
    remote=$(curl -fsSL --max-time 3 \
      "https://api.github.com/repos/Ahasseyp/gswitch/releases/latest" 2>/dev/null \
      | grep '"tag_name"' | head -1 \
      | sed 's/.*"tag_name": *"v\{0,1\}\([^"]*\)".*/\1/' || true)
    local_v=$(cat "${HOME}/.local/share/gswitch/version" 2>/dev/null | tr -d '[:space:]' || true)
    [[ -n "$remote" && -n "$local_v" && "$remote" != "$local_v" ]] && \
      echo "gswitch update available ($local_v → $remote). Run: gsupdate"
  ) &
fi
